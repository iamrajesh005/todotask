<% layout('layout/templog') -%>
<div class="flex justify-center items-center bg-gradient-to-l from-sky-500 to-blue-800 min-h-screen">
   <div class="card w-156 h-106 bg-base-100 shadow-sm ">
  <div class="card-body flex flex-col justify-around">
    <span class="badge badge-xs badge-warning">Register Now</span>
    <div class="flex justify-between">
      <h2 class="text-3xl font-bold">Sign Up</h2>
   </div>
<form action="/todo/signup" method="post" >
        <label for="name" class="text-xl">Name</label>
        <input name="yourname" placeholder="Enter your name" id="name">
        <br>
        <br>
        <br>
         <label for="username" class="text-xl">username</label>
        <input name="username" placeholder="Enter an unique username" id="username">
        <br>
        <br>
        <br>
         <label for="email" class="text-xl">Email<small>(xyzabc@gmail.com)</small></label>
        <input name="email" placeholder="Enter an valid email" id="email">
        <br>
        <br>
        <br>
         <label for="password" class="text-xl">Name</label>
        <input name="password" placeholder="Enter an strong password" id="password">
        <br>
        <br>
        
        <div class="mt-6">
         <button class="btn btn-primary btn-block">register</button>
        </div>
    </form>
  </div>
</div>
</div>
